{
  "_version": "1.12.0",
  "sap.app": {
    "id": "myApp",
    "type": "application",
    "i18n": "i18n/i18n.properties",
    "title": "Luxury Home Decor BI",
    "applicationVersion": {
      "version": "1.0.0"
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "icons": {
      "icon": ""
    }
  },
  "sap.ui5": {
    "rootView": {
      "viewName": "myApp.view.App",
      "type": "XML",
      "id": "app"
    },
    "dependencies": {
      "minUI5Version": "1.100.0",
      "libs": {
        "sap.m": {}
      },
      "sap.viz": {},
      "sap.ui.layout": {}
    },
    "models": {},
    "routing": {
      "config": {
        "routerClass": "sap.m.routing.Router",
        "viewType": "XML",
        "viewPath": "myApp.view",
        "controlId": "app",
        "controlAggregation": "pages",
        "async": true
      },
      "routes": [
        {
          "pattern": "",
          "name": "Login",
          "target": "Login"
        },
        {
          "pattern": "ceo",
          "name": "CEODashboard",
          "target": "CEODashboard"
        },
        {
          "pattern": "sales",
          "name": "SalesDashboard",
          "target": "SalesDashboard"
        },
        {
          "pattern": "inventory",
          "name": "InventoryDashboard",
          "target": "InventoryDashboard"
        },
        {
          "pattern": "admin",
          "name": "ADMINDashboard",
          "target": "ADMINDashboard"
        }
      ],
      "targets": {
        "Login":              { "viewName": "Login" },
        "CEODashboard":       { "viewName": "CEODashboard" },
        "SalesDashboard":     { "viewName": "SalesDashboard" },
        "InventoryDashboard": { "viewName": "InventoryDashboard" },
        "ADMINDashboard":     { "viewName": "ADMINDashboard" }
      }
    }
  }
}
