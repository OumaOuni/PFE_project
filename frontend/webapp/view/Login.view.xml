<mvc:View
    controllerName="myApp.controller.Login"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m">

    <App>
        <Page title="Login - Luxury Home Decor BI">
            <content>
                <VBox class="sapUiSmallMargin"
                       justifyContent="Center"
                       alignItems="Center"
                       height="100%">

                    <Input
                        placeholder="Username"
                        value="{/username}"
                        width="300px"/>

                    <Input
                        placeholder="Password"
                        value="{/password}"
                        type="Password"
                        width="300px"
                        class="sapUiSmallMarginTop"/>

                    <Button
                        text="Login"
                        type="Emphasized"
                        width="150px"
                        class="sapUiSmallMarginTop"
                        press="login"/>

                </VBox>
            </content>
        </Page>
    </App>
</mvc:View>